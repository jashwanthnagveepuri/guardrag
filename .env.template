# GuardRAG Application Settings
GUARDRAG_APP_NAME=GuardRAG
GUARDRAG_APP_VERSION=1.0.0
GUARDRAG_APP_DEBUG=false
GUARDRAG_APP_ENV=production

# API Settings
GUARDRAG_API_HOST=0.0.0.0
GUARDRAG_API_PORT=8000
GUARDRAG_API_WORKERS=1

# Database Settings
GUARDRAG_DATABASE_URL=postgresql+asyncpg://guardrag:guardrag@localhost:5432/guardrag

# ChromaDB Settings
GUARDRAG_CHROMADB_HOST=localhost
GUARDRAG_CHROMADB_PORT=8000
GUARDRAG_CHROMADB_COLLECTION_NAME=guardrag_chunks

# OpenAI Settings
GUARDRAG_OPENAI_API_KEY=sk-your-openai-api-key-here
GUARDRAG_OPENAI_MODEL=gpt-4o
GUARDRAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
GUARDRAG_OPENAI_TEMPERATURE=0.1

# Chunking Settings
GUARDRAG_CHUNKING_CHUNK_SIZE=512
GUARDRAG_CHUNKING_CHUNK_OVERLAP=50
GUARDRAG_CHUNKING_STRATEGY=recursive

# Retrieval Settings
GUARDRAG_RETRIEVAL_TOP_K=5
GUARDRAG_RETRIEVAL_MMR_FETCH_K=20
GUARDRAG_RETRIEVAL_MMR_LAMBDA=0.5
GUARDRAG_RETRIEVAL_RERANK_TOP_K=3

# Guardrail Settings
GUARDRAG_GUARDRAIL_INPUT_THRESHOLD=0.75
GUARDRAG_GUARDRAIL_OUTPUT_THRESHOLD=0.5

# Upload Settings
GUARDRAG_UPLOAD_MAX_FILE_SIZE=52428800
GUARDRAG_UPLOAD_ALLOWED_TYPES=application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Redis Settings
GUARDRAG_REDIS_URL=redis://localhost:6379/0
